# Copy to .env and adjust. .env is gitignored.
# All values here are dev-only — never ship these credentials anywhere real.

# --- Postgres (source) ---
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5432

# Debezium replication user (has REPLICATION privilege)
POSTGRES_REPL_USER=debezium
POSTGRES_REPL_PASSWORD=debezium

# --- Kafka ---
KAFKA_CLUSTER_ID=zdt-migration-cluster
KAFKA_EXTERNAL_PORT=9092

# --- Kafka Connect / Debezium ---
CONNECT_REST_PORT=8083
CONNECT_GROUP_ID=zdt-connect
CONNECT_CONFIG_STORAGE_TOPIC=_connect_configs
CONNECT_OFFSET_STORAGE_TOPIC=_connect_offsets
CONNECT_STATUS_STORAGE_TOPIC=_connect_status

# --- Schema Registry ---
SCHEMA_REGISTRY_PORT=8081

# --- MongoDB (sink) ---
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root
MONGO_DB=migration
MONGO_PORT=27017
MONGO_REPLICA_SET=rs0

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
